FROM node:22-bookworm-slim

WORKDIR /app

RUN corepack enable

# Install CLI providers used by Claw-Empire agent runtime
# NOTE: opencode package name is not currently resolvable from npm in this environment,
# so install core CLIs first and keep opencode as best-effort.
RUN npm install -g \
  @anthropic-ai/claude-code \
  @openai/codex \
  @google/gemini-cli \
  && (npm install -g opencode || echo "[WARN] opencode npm package not found; skipped")

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm build

EXPOSE 8790

CMD ["pnpm", "start:tailscale"]
